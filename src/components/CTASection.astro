          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </a>
        <a href="/architecture" class="btn-secondary text-base">
          Download the one-pager
        </a>
      </div>

      <p class="mt-6 text-xs text-deep-500">
        No commitment required. We'll share a detailed architecture assessment after the first call.
      </p>
    </div>
