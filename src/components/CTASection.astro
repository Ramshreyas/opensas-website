      <!-- Decorative corner accents -->
      <div class="pointer-events-none absolute top-0 left-0 h-24 w-24">
        <div class="absolute top-0 left-0 h-8 w-px bg-accent/30" />
        <div class="absolute top-0 left-0 h-px w-8 bg-accent/30" />
      </div>
      <div class="pointer-events-none absolute top-0 right-0 h-24 w-24">
