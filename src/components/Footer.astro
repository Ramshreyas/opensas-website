---
import { primaryNav } from "../data/navigation";
---

<footer class="border-t border-deep-700/50 bg-deep-900">
  <div class="mx-auto max-w-7xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 sm:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2 text-lg font-bold text-white">
          <span class="flex h-8 w-8 items-center justify-center rounded-md bg-accent text-xs font-bold text-deep-900">
            OS
          </span>
          Open<span class="text-accent">SAS</span>
        </a>
        <p class="mt-3 text-sm leading-relaxed text-deep-400 max-w-xs">
          Private AI infrastructure, deployed on your terms. No data exposure. No vendor lock-in.
        </p>
      </div>

      <!-- Nav -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-deep-400">Navigate</h4>
        <ul class="mt-4 space-y-2">
          {primaryNav.map((item) => (
            <li>
              <a href={item.href} class="text-sm text-deep-400 transition-colors hover:text-white">
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- CTA -->
      <div>
        <h4 class="text-xs font-semibold uppercase tracking-widest text-deep-400">Get started</h4>
        <div class="mt-4 space-y-3">
          <a href="/contact" class="btn btn-primary text-sm">
            Schedule a discovery call
          </a>
          <br />
          <a href="/architecture" class="text-sm text-deep-400 transition-colors hover:text-white">
            Read the architecture →
          </a>
        </div>
      </div>
    </div>

    <div class="mt-10 border-t border-deep-700/50 pt-6 flex flex-col items-center justify-between gap-4 sm:flex-row">
      <p class="text-xs text-deep-500">
        &copy; {new Date().getFullYear()} OpenSAS. All components are Apache 2.0 licensed.
      </p>
      <p class="text-xs text-deep-500">
        Infrastructure, not magic.
      </p>
    </div>
  </div>
</footer>
