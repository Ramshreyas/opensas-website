---
const steps = [
  {
    week: "1–2",
    title: "We design your private AI architecture",
    items: [
      "We map your existing infrastructure, compliance requirements, and the workflows you want to automate.",
      "We select the right AI models and components for your specific workload — not a one-size-fits-all configuration.",
      "You receive a detailed architecture document and deployment plan to review and approve before we build anything.",
    ],
  },
  {
    week: "3–4",
    title: "We deploy everything in your environment",
    items: [
      "We install and configure the full stack inside your own infrastructure — nothing is hosted on our servers.",
      "All deployment templates, configuration files, and automation scripts are handed over to your team.",
      "End-to-end tests confirm every component is working before we move to the next phase.",
    ],
  },
  {
    week: "5–6",
    title: "We build your first AI workflows",
    items: [
      "We build your first 3 production AI workflows — document review, compliance checking, code assistance, or whatever your team needs most.",
      "Your engineers learn to operate, troubleshoot, and extend the stack through hands-on working sessions.",
      "Full documentation: architecture diagrams, operations runbooks, and step-by-step incident response guides.",
    ],
  },
  {
    week: "7–8",
    title: "Go-live and post-deployment support",
    items: [
      "Production cutover with your team in control — you own it from day one.",
      "Performance benchmarks and cost baselines established so you know exactly what you're running.",
      "Optional retainer for ongoing workflow development and optimization — no forced subscription.",
    ],
  },
];
---

<section id="how-it-works" class="py-20 sm:py-28">
  <hr class="section-divider" />
  <div class="mx-auto max-w-7xl px-4 pt-20 sm:px-6 lg:px-8">
    <div class="section-header">
      <h2>From zero to production in 6–8 weeks</h2>
      <p>
        A done-for-you engagement — not a DIY toolkit.
        Your team owns the stack at the end.
      </p>
    </div>

    <div class="mt-12 relative mx-auto max-w-3xl">
      <!-- Timeline spine -->
      <div class="absolute top-5 bottom-5 left-[19px] w-px hidden md:block"
        style="background: linear-gradient(to bottom, var(--color-accent), rgba(20,184,166,0.4), rgba(255,255,255,0.04));" />

      <div class="space-y-6">
        {steps.map((step) => (
          <div class="relative flex gap-6 md:gap-8">
            <!-- Step indicator -->
            <div class="flex-shrink-0 flex flex-col items-center gap-1.5 pt-0.5" style="width: 40px;">
              <div
                class="relative z-10 flex h-10 w-10 items-center justify-center rounded-full font-mono text-xs font-bold"
                style={`background: linear-gradient(135deg, var(--color-accent) 0%, var(--color-accent-hover) 100%); color: #050a0f; box-shadow: 0 0 0 3px rgba(245,158,11,0.15), 0 4px 12px rgba(245,158,11,0.25);`}>
                {step.week}
              </div>
            </div>

            <!-- Card -->
            <div class="flex-1 pb-2">
              <div class="card">
                <div class="mb-1 font-mono text-[10px] font-semibold uppercase tracking-widest" style="color: var(--color-accent); opacity: 0.7;">
                  Week {step.week}
                </div>
                <h3 class="text-[0.9375rem] font-semibold text-white">{step.title}</h3>
                <ul class="mt-3 space-y-2">
                  {step.items.map((item) => (
                    <li class="flex gap-2.5 text-sm" style="color: var(--color-deep-400);">
                      <span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full" style="background: rgba(245,158,11,0.35);" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Deliverables -->
    <div class="mt-16 mx-auto max-w-3xl">
      <p class="mb-5 text-center text-xs font-semibold uppercase tracking-widest" style="color: var(--color-deep-400);">
        What your team receives at handover
      </p>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-4">
        {[
          { label: "Deployment Templates", desc: "Configs, scripts, and automation" },
          { label: "Security Assessment", desc: "Threat model and access control setup" },
          { label: "Hands-On Training", desc: "Live ops and troubleshooting sessions" },
          { label: "Optional Retainer", desc: "Ongoing support on your terms" },
        ].map((item) => (
          <div class="deliverable-box">
            <div class="text-sm font-semibold text-white">{item.label}</div>
            <div class="mt-1 text-xs leading-relaxed" style="color: var(--color-deep-400);">{item.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
