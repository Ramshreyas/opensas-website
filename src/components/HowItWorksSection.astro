---
const steps = [
  {
    week: "1–2",
    title: "We design your private AI architecture",
    items: [
      "We map your existing infrastructure, compliance requirements, and the workflows you want to automate.",
      "We select the right AI models and components for your specific workload — not a one-size-fits-all configuration.",
      "You receive a detailed architecture document and deployment plan to review and approve before we build anything.",
    ],
  },
  {
    week: "3–4",
    title: "We deploy everything in your environment",
    items: [
      "We install and configure the full stack inside your own infrastructure — nothing is hosted on our servers.",
      "All deployment templates, configuration files, and automation scripts are handed over to your team.",
      "End-to-end tests confirm every component is working before we move to the next phase.",
    ],
  },
  {
    week: "5–6",
    title: "We build your first AI workflows",
    items: [
      "We build your first 3 production AI workflows — document review, compliance checking, code assistance, or whatever your team needs most.",
      "Your engineers learn to operate, troubleshoot, and extend the stack through hands-on working sessions.",
      "Full documentation: architecture diagrams, operations runbooks, and step-by-step incident response guides.",
    ],
  },
  {
    week: "7–8",
    title: "Go-live and post-deployment support",
    items: [
      "Production cutover with your team in control — you own it from day one.",
      "Performance benchmarks and cost baselines established so you know exactly what you're running.",
      "Optional retainer for ongoing workflow development and optimization — no forced subscription.",
    ],
  },
];
---

<section id="how-it-works" class="border-t border-deep-700/50 py-20 sm:py-28">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="section-header">
      <h2>From zero to production in 6–8 weeks</h2>
      <p>
        This isn't a DIY toolkit you assemble yourself. It's a done-for-you engagement.
        Your team owns the stack at the end.
      </p>
    </div>

    <div class="mt-12 relative">
      <!-- Timeline line -->
      <div class="absolute top-0 bottom-0 left-[18px] hidden w-px bg-gradient-to-b from-accent via-mesh to-deep-600 md:block" />

      <div class="space-y-8 md:space-y-12">
        {steps.map((step) => (
          <div class="relative md:flex md:gap-8">
            <!-- Week badge -->
            <div class="flex items-center gap-4 md:w-32 md:flex-col md:items-start md:gap-1">
              <div class="relative z-10 flex h-9 w-9 items-center justify-center rounded-full bg-accent text-xs font-bold text-deep-900 shadow-lg shadow-accent/20 md:h-10 md:w-10" style="font-family: 'JetBrains Mono', monospace;">
                {step.week}
              </div>
              <span class="text-xs font-semibold uppercase tracking-wider text-accent md:text-[10px]">
                Week {step.week}
              </span>
            </div>

            <!-- Step card -->
            <div class="mt-3 flex-1 md:mt-0">
              <div class="card">
                <h3 class="text-base font-semibold text-white">{step.title}</h3>
                <ul class="mt-3 space-y-2">
                  {step.items.map((item) => (
                    <li class="flex gap-2 text-sm text-deep-400">
                      <span class="mt-1.5 block h-1.5 w-1.5 flex-shrink-0 rounded-full bg-accent/40" />
                      {item}
                    </li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Deliverables summary -->
    <div class="mt-16 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
      {[
        { label: "Deployment Templates", desc: "Configuration files, automation scripts, and everything your team needs to reproduce or extend the stack" },
        { label: "Security Assessment", desc: "Threat model, access control config, and audit logging setup for your environment" },
        { label: "Hands-On Training", desc: "Live sessions with your engineers covering operations, troubleshooting, and day-2 management" },
        { label: "Optional Retainer", desc: "Continued support for new workflow development, upgrades, and optimization — on your terms" },
      ].map((item) => (
        <div class="rounded-lg border border-deep-700 bg-deep-800/30 p-4 text-center transition-colors hover:border-deep-600">
          <div class="text-sm font-semibold text-white">{item.label}</div>
          <div class="mt-1 text-xs leading-relaxed text-deep-400">{item.desc}</div>
        </div>
      ))}
    </div>
  </div>
</section>
