---
import { faqItems } from "../data/faq";
---

<section id="faq" class="py-20 sm:py-28">
  <hr class="section-divider" />
  <div class="mx-auto max-w-3xl px-4 pt-20 sm:px-6 lg:px-8">
    <div class="section-header">
      <h2>Common questions</h2>
      <p>Straight answers about fit, cost, and how deployment works.</p>
    </div>

    <div class="mt-10 space-y-2">
      {faqItems.map((item) => (
        <details class="faq-item group">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-5 py-4 text-base font-medium text-white">
            <span>{item.question}</span>
            <svg
              class="h-4 w-4 flex-shrink-0 transition-transform duration-200 group-open:rotate-45"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
              style="color: var(--color-deep-400);"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="px-5 pb-5 pt-0">
            <div class="h-px w-full mb-4" style="background: rgba(255,255,255,0.04);"></div>
            <p class="text-base leading-relaxed" style="color: var(--color-deep-400);">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>

    <p class="mt-8 text-center text-sm" style="color: var(--color-deep-500);">
      More technical questions? <a href="/architecture#faq" class="transition-colors hover:text-white" style="color: var(--color-deep-400);">See the architecture FAQ →</a>
    </p>
  </div>
</section>
