---
import { faqItems } from "../data/faq";
---

<section id="faq" class="border-t border-deep-700/50 py-20 sm:py-28">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
    <div class="section-header">
      <h2>For engineers</h2>
      <p>Technical answers about deployment, models, pricing, and operations.</p>
    </div>

    <div class="mt-12 space-y-3">
      {faqItems.map((item) => (
        <details class="group rounded-xl border border-deep-700 bg-deep-800/30 transition-colors hover:border-deep-600">
          <summary class="flex cursor-pointer items-center justify-between gap-4 p-5 text-sm font-medium text-white">
            <span>{item.question}</span>
            <svg
              class="h-4 w-4 flex-shrink-0 text-deep-400 transition-transform duration-200 group-open:rotate-45"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
            </svg>
          </summary>
          <div class="border-t border-deep-700/50 px-5 pb-5 pt-3">
            <p class="text-sm leading-relaxed text-deep-400">{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>
