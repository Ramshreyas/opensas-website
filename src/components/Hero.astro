---
import StackDiagram from "./StackDiagram.astro";
---

<section class="relative overflow-hidden pt-28 pb-16 sm:pt-36 sm:pb-24">
  <!-- Background grid -->
  <div class="bg-grid pointer-events-none absolute inset-0 opacity-50" />

  <!-- Gradient glow orbs -->
  <div class="pointer-events-none absolute top-20 left-1/4 h-96 w-96 -translate-x-1/2 rounded-full bg-accent/5 blur-3xl" />
  <div class="pointer-events-none absolute top-40 right-1/4 h-80 w-80 rounded-full bg-mesh/5 blur-3xl" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
      <!-- Left: copy -->
      <div class="max-w-xl">
        <div class="mb-6 inline-flex items-center gap-2 rounded-full border border-deep-600/50 bg-deep-800/50 px-4 py-1.5 text-xs font-medium text-deep-400">
          <span class="flex h-2 w-2 rounded-full bg-accent" />
          Sovereign Automation Stack — v1.0
        </div>

        <h1 class="text-4xl font-extrabold leading-tight tracking-tight text-white sm:text-5xl lg:text-6xl">
          <span class="text-accent-gradient">Sovereign Automation Stack</span>
          <br />
          Your agents, your infra, fully under your control.
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-deep-400 sm:text-xl">
          <strong class="text-white">Zero data leak, zero vendor lock-in.</strong>
          OpenSAS is the infrastructure you'd build for production AI workloads — if you had a dedicated team and 8 weeks.
          We give you the blueprint, the integration, and the handover.
          <strong class="text-white">You keep the keys.</strong>
        </p>

        <!-- Key differentiators -->
        <div class="mt-8 flex flex-wrap gap-4">
          <div class="flex items-center gap-2 text-sm text-deep-400">
            <svg class="h-4 w-4 text-mesh" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            No data leaves your network
          </div>
          <div class="flex items-center gap-2 text-sm text-deep-400">
            <svg class="h-4 w-4 text-mesh" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            Any open-weight model
          </div>
          <div class="flex items-center gap-2 text-sm text-deep-400">
            <svg class="h-4 w-4 text-mesh" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            6–8 week deployment
          </div>
        </div>

        <!-- CTAs -->
        <div class="mt-10 flex flex-wrap gap-4">
          <a href="/contact" class="btn-primary text-base">
            Deploy your first agent in 6 weeks
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/architecture" class="btn-secondary text-base">
            See the blueprint
          </a>
        </div>
      </div>

      <!-- Right: stack diagram -->
      <div class="lg:justify-self-end">
        <StackDiagram />
      </div>
    </div>
  </div>
</section>
