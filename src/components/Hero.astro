---
import StackDiagram from "./StackDiagram.astro";
---

<section class="relative overflow-hidden pt-28 pb-20 sm:pt-36 sm:pb-28">
  <!-- Grid -->
  <div class="bg-grid pointer-events-none absolute inset-0 opacity-100" />

  <!-- Subtle amber orb top-left of copy -->
  <div class="pointer-events-none absolute top-16 left-0 h-[500px] w-[500px] -translate-x-1/3 rounded-full bg-amber-500/5 blur-[100px]" />
  <!-- Subtle teal orb behind diagram -->
  <div class="pointer-events-none absolute top-32 right-0 h-[400px] w-[400px] translate-x-1/3 rounded-full bg-teal-500/5 blur-[100px]" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-20">

      <!-- Left: copy -->
      <div class="max-w-xl">

        <!-- Badge -->
        <div class="mb-8 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5"
          style="background: linear-gradient(135deg, rgba(245,158,11,0.08) 0%, rgba(20,184,166,0.04) 100%); border: 1px solid rgba(245,158,11,0.15); font-family: 'IBM Plex Sans', sans-serif; font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.09em; text-transform: uppercase; color: rgba(245,158,11,0.8);">
          <span class="flex h-1.5 w-1.5 rounded-full bg-accent" style="box-shadow: 0 0 6px rgba(245,158,11,0.8);"></span>
          Private AI Deployment Service
        </div>

        <!-- Headline -->
        <h1 style="font-family: 'Syne', sans-serif; font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 700; line-height: 1.25; letter-spacing: -0.015em;">
          <span style="display: block; color: white;">Run AI on your own servers.</span>
          <span class="text-signal" style="display: block;">Not theirs.</span>
        </h1>

        <!-- Description -->
        <p class="mt-6 text-base leading-relaxed sm:text-lg" style="color: var(--color-deep-300); max-width: 30rem;">
          OpenSAS deploys a complete, private AI automation stack on your infrastructure in 6–8 weeks.
          Sensitive data never leaves your network. Your team owns the stack outright when we're done.
        </p>

        <!-- Stats -->
        <div class="mt-8 flex items-stretch gap-0 overflow-hidden rounded-xl"
          style="border: 1px solid rgba(255,255,255,0.06); background: rgba(13,21,32,0.7);">
          {[
            { value: "0", label: "bytes to\nthird parties" },
            { value: "6 wks", label: "kickoff to\nproduction" },
            { value: "100%", label: "open-source\nyou own it" },
          ].map((stat, i) => (
            <div class="flex flex-1 flex-col items-center justify-center px-4 py-5 text-center"
              style={i < 2 ? "border-right: 1px solid rgba(255,255,255,0.05);" : ""}>
              <div class="stat-number" style="font-size: clamp(1.5rem, 3vw, 2rem);">{stat.value}</div>
              <div class="mt-1.5 whitespace-pre text-center leading-snug"
                style="font-size: 0.6875rem; color: var(--color-deep-400); font-family: 'IBM Plex Sans', sans-serif;">
                {stat.label}
              </div>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary text-sm">
            Schedule a discovery call
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/architecture" class="btn btn-secondary text-sm">
            See how it works
          </a>
        </div>

      </div>

      <!-- Right: stack diagram -->
      <div class="lg:justify-self-end">
        <StackDiagram />
      </div>

    </div>
  </div>
</section>
