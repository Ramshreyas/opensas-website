---
const services = [
  { name: "Private AI inference",    assurance: "no external API calls" },
  { name: "Workflow automation",     assurance: "connects existing tools" },
  { name: "Complete audit trail",    assurance: "every action logged" },
  { name: "Secure access control",   assurance: "compliance-ready" },
  { name: "Any open-source model",   assurance: "no vendor lock-in" },
];
---

<section class="relative overflow-hidden pt-28 pb-20 sm:pt-36 sm:pb-28">
  <!-- Grid -->
  <div class="bg-grid pointer-events-none absolute inset-0" />

  <!-- Amber orb left -->
  <div class="pointer-events-none absolute top-16 left-0 h-[500px] w-[500px] -translate-x-1/3 rounded-full bg-amber-500/5 blur-[100px]" />
  <!-- Teal orb right -->
  <div class="pointer-events-none absolute top-32 right-0 h-[400px] w-[400px] translate-x-1/3 rounded-full bg-teal-500/5 blur-[100px]" />

  <div class="relative mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="grid items-center gap-16 lg:grid-cols-2">

      <!-- Left: copy -->
      <div class="max-w-lg">

        <!-- Badge -->
        <div class="mb-8 inline-flex items-center gap-2.5 rounded-full px-4 py-1.5"
          style="background: rgba(245,158,11,0.07); border: 1px solid rgba(245,158,11,0.18); font-family: 'Plus Jakarta Sans', sans-serif; font-size: 0.75rem; font-weight: 500; letter-spacing: 0.09em; text-transform: uppercase; color: rgba(245,158,11,0.75);">
          <span class="h-1.5 w-1.5 rounded-full" style="background: var(--color-accent);"></span>
          Private AI Deployment Service
        </div>

        <!-- Headline -->
        <h1 style="font-family: 'Plus Jakarta Sans', sans-serif; font-size: clamp(1.875rem, 3.5vw, 2.75rem); font-weight: 700; line-height: 1.25; letter-spacing: -0.015em;">
          <span style="display: block; color: white;">Run AI on your own servers.</span>
          <span class="text-signal" style="display: block;">Not theirs.</span>
        </h1>

        <!-- Description -->
        <p class="mt-5 text-base leading-relaxed" style="color: var(--color-deep-300); max-width: 30rem;">
          OpenSAS deploys a complete, private AI automation stack on your infrastructure in 6–8 weeks.
          Sensitive data never leaves your network. Your team owns the stack outright when we're done.
        </p>

        <!-- Stats -->
        <div class="mt-8 flex items-stretch overflow-hidden rounded-xl"
          style="border: 1px solid rgba(255,255,255,0.06); background: rgba(13,21,32,0.7);">
          {[
            { value: "0",     label: "bytes to\nthird parties" },
            { value: "6 wks", label: "kickoff to\nproduction" },
            { value: "100%",  label: "open-source\nyou own it" },
          ].map((stat, i) => (
            <div class="flex flex-1 flex-col items-center justify-center px-4 py-5 text-center"
              style={i < 2 ? "border-right: 1px solid rgba(255,255,255,0.05);" : ""}>
              <div class="stat-number" style="font-size: clamp(1.375rem, 2.5vw, 1.875rem);">{stat.value}</div>
              <div class="mt-1.5 whitespace-pre text-center leading-snug"
                style="font-size: 0.75rem; color: var(--color-deep-400); font-family: 'Plus Jakarta Sans', sans-serif;">{stat.label}</div>
            </div>
          ))}
        </div>

        <!-- CTAs -->
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="/contact" class="btn btn-primary text-sm">
            Schedule a discovery call
            <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </a>
          <a href="/architecture" class="btn btn-secondary text-sm">
            See how it works
          </a>
        </div>
      </div>

      <!-- Right: status board -->
      <div class="lg:justify-self-end w-full max-w-sm">
        <div class="overflow-hidden rounded-xl"
          style="background: var(--color-deep-800); border: 1px solid rgba(255,255,255,0.07); box-shadow: 0 24px 64px rgba(0,0,0,0.4);">

          <!-- Terminal title bar -->
          <div class="flex items-center gap-3 px-4 py-3"
            style="border-bottom: 1px solid rgba(255,255,255,0.05); background: rgba(255,255,255,0.02);">
            <div class="flex gap-1.5">
              <span class="h-3 w-3 rounded-full" style="background: rgba(239,68,68,0.4);"></span>
              <span class="h-3 w-3 rounded-full" style="background: rgba(245,158,11,0.4);"></span>
              <span class="h-3 w-3 rounded-full" style="background: rgba(34,197,94,0.4);"></span>
            </div>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; color: var(--color-deep-400);">
              opensas — your infrastructure
            </span>
          </div>

          <!-- Services list -->
          <div class="px-5 py-4 space-y-0">
            {services.map((s, i) => (
              <div class="flex items-center justify-between gap-4 py-3"
                style={i < services.length - 1 ? "border-bottom: 1px solid rgba(255,255,255,0.04);" : ""}>
                <div class="flex items-center gap-2.5">
                  <svg class="h-4 w-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
                    style="color: var(--color-mesh);">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7" />
                  </svg>
                  <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.875rem; color: var(--color-deep-200);">
                    {s.name}
                  </span>
                </div>
                <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; color: var(--color-deep-500); white-space: nowrap;">
                  {s.assurance}
                </span>
              </div>
            ))}
          </div>

          <!-- Footer: self-hosted statement -->
          <div class="flex items-center justify-between px-5 py-3"
            style="border-top: 1px solid rgba(255,255,255,0.05); background: rgba(245,158,11,0.03);">
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 0.8125rem; color: var(--color-deep-400);">
              external API calls
            </span>
            <span style="font-family: 'JetBrains Mono', monospace; font-size: 1rem; font-weight: 700; color: var(--color-accent);">
              none
            </span>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
