---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="Contact — OpenSAS"
  description="Schedule a discovery call with the OpenSAS team. Deploy your first autonomous agent in 6-8 weeks."
>
  <Header />
  <main>
    <section class="pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <!-- Header -->
        <div class="text-center">
          <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Schedule a discovery call</h1>
          <p class="mt-4 text-lg text-deep-400 max-w-xl mx-auto">
            Tell us about your infrastructure and AI goals. We'll share a detailed architecture
            assessment after our first conversation — no commitment required.
          </p>
        </div>

        <!-- Form -->
        <div class="mt-12">
          <form
            id="contact-form"
            class="space-y-6"
            data-netlify="true"
            name="contact"
            method="POST"
            action="/contact/thanks"
          >
            <input type="hidden" name="form-name" value="contact" />

            <div class="grid gap-6 sm:grid-cols-2">
              <div>
                <label for="name" class="block text-sm font-medium text-deep-200">Name</label>
                <input
                  type="text"
                  id="name"
                  name="name"
                  required
                  class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white placeholder-deep-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                  placeholder="Your name"
                />
              </div>
              <div>
                <label for="email" class="block text-sm font-medium text-deep-200">Work email</label>
                <input
                  type="email"
                  id="email"
                  name="email"
                  required
                  class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white placeholder-deep-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                  placeholder="you@company.com"
                />
              </div>
            </div>

            <div>
              <label for="company" class="block text-sm font-medium text-deep-200">Company / Organization</label>
              <input
                type="text"
                id="company"
                name="company"
                required
                class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white placeholder-deep-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                placeholder="Company name"
              />
            </div>

            <div>
              <label for="role" class="block text-sm font-medium text-deep-200">Role</label>
              <select
                id="role"
                name="role"
                required
                class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
              >
                <option value="">Select your role</option>
                <option value="ciso">CISO / Security Architect</option>
                <option value="cto">CTO / VP Engineering</option>
                <option value="devops">DevOps / Platform Engineer</option>
                <option value="other">Other</option>
              </select>
            </div>

            <div>
              <label for="infra" class="block text-sm font-medium text-deep-200">Current infrastructure</label>
              <textarea
                id="infra"
                name="infrastructure"
                rows={3}
                class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white placeholder-deep-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                placeholder="K8s? Bare metal? Cloud? GPUs? (Optional, but helpful)"
              />
            </div>

            <div>
              <label for="message" class="block text-sm font-medium text-deep-200">What are you looking to build?</label>
              <textarea
                id="message"
                name="message"
                rows={4}
                required
                class="mt-1 block w-full rounded-lg border border-deep-600 bg-deep-800 px-4 py-2.5 text-sm text-white placeholder-deep-500 focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent"
                placeholder="Tell us about your AI use cases, constraints, and timeline..."
              />
            </div>

            <button type="submit" class="btn-primary w-full justify-center text-base">
              Send request
              <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
              </svg>
            </button>
          </form>

          <p class="mt-6 text-center text-xs text-deep-500">
            We'll respond within 1 business day. No sales pitch — just a technical conversation about your infrastructure.
          </p>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
