---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import ProblemSection from "../components/ProblemSection.astro";
import UseCasesSection from "../components/UseCasesSection.astro";
import HowItWorksSection from "../components/HowItWorksSection.astro";
import FAQSection from "../components/FAQSection.astro";
import CTASection from "../components/CTASection.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout
  title="OpenSAS — Private AI Infrastructure"
  description="Deploy a complete, self-hosted AI automation stack on your own servers in 6–8 weeks. No data leaves your network. No vendor lock-in. Your team owns it outright."
>
  <Header />
  <main>
    <Hero />
    <ProblemSection />
    <UseCasesSection />
    <HowItWorksSection />
    <FAQSection />
    <CTASection />
  </main>
  <Footer />
</BaseLayout>
