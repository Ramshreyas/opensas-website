---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import { getCollection } from "astro:content";

const posts = await getCollection("blog", ({ data }) => !data.draft);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="Blog — OpenSAS"
  description="Technical posts, architecture walkthroughs, benchmarks, and update logs from the OpenSAS team."
>
  <Header />
  <main>
    <section class="pt-28 pb-20 sm:pt-36 sm:pb-28">
      <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
        <div class="text-center">
          <h1 class="text-4xl font-extrabold text-white sm:text-5xl">Blog</h1>
          <p class="mt-4 text-lg text-deep-400 max-w-xl mx-auto">
            Technical posts, architecture walkthroughs, benchmarks, and update logs.
          </p>
        </div>

        <div class="mt-12 space-y-6">
          {posts.length === 0 && (
            <p class="text-center text-deep-400">No posts yet. Check back soon.</p>
          )}
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="card group block hover:border-deep-600">
              <div class="flex items-start justify-between gap-4">
                <div class="flex-1">
                  <div class="flex items-center gap-3">
                    <time class="text-xs text-deep-500" datetime={post.data.pubDate.toISOString()}>
                      {post.data.pubDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "short",
                        day: "numeric",
                      })}
                    </time>
                    {post.data.tags.slice(0, 2).map((tag) => (
                      <span class="rounded bg-deep-700/50 px-2 py-0.5 text-[10px] font-medium text-deep-400">
                        {tag}
                      </span>
                    ))}
                  </div>
                  <h2 class="mt-2 text-lg font-semibold text-white group-hover:text-accent transition-colors">
                    {post.data.title}
                  </h2>
                  <p class="mt-1 text-sm text-deep-400">{post.data.description}</p>
                </div>
                <svg class="mt-1 h-5 w-5 flex-shrink-0 text-deep-600 group-hover:text-accent transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
                </svg>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
